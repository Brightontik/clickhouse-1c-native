// Выполняет высокопроизводительную вставку массива строк в формате TSV.
// При возникновении ошибок фиксирует их в Журнале Регистрации и прерывает выполнение операции.
//
// Параметры:
//  ИмяТаблицы               - Строка - Целевая таблица в ClickHouse (например, "db.metrics").
//  СтрокаДанныхTSV          - Строка - Пакет данных, разделенный табуляциями и переносами строк.
//  ВыполнятьПроверкуТаблицы - Булево - Флаг принудительной валидации структуры таблицы перед вставкой.
//
Процедура ВыполнитьПакетнуюВставку(Знач ИмяТаблицы, Знач СтрокаДанныхTSV, Знач ВыполнятьПроверкуТаблицы = Ложь) Экспорт
	ВК = КХ_ЯдроПовИсп.ПолучитьПодключениеClickHouse();
	Если ВК = Неопределено Тогда
		ВызватьИсключение "Не удалось получить активное подключение к ядру ClickHouse.";
	КонецЕсли;
	
	Попытка
		Результат = ВК.ПакетнаяВставка(ИмяТаблицы, СтрокаДанныхTSV, ВыполнятьПроверкуТаблицы);
		ЧистыйРезультат = КХ_ИнтеграцияСлужебный.ОчиститьСтрокуОтНулей(Результат);
		Если ЧистыйРезультат <> "OK" Тогда
			ВызватьИсключение ЧистыйРезультат;
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации("ClickHouse.Данные", УровеньЖурналаРегистрации.Ошибка,,, 
			"Ошибка пакетной вставки в таблицу '" + ИмяТаблицы + "': " + ОписаниеОшибки());
		ВызватьИсключение ОписаниеОшибки();
	КонецПопытки;
КонецПроцедуры
// Выполняет произвольный SQL-запрос к ClickHouse (SELECT, ALTER, OPTIMIZE и др.).
// В случае успеха возвращает очищенный от служебных нулей текстовый ответ сервера.
// При ошибках выполнения генерирует исключение 1С.
//
// Параметры:
//  ТекстЗапросаSQL - Строка - Текст SQL-запроса для отправки на сервер.
//
// Возвращаемое значение:
//  Строка - Текст ответа ClickHouse (обычно в формате JSON).
//
Функция ВыполнитьЗапрос(Знач ТекстЗапросаSQL) Экспорт
	
	ВК = КХ_ЯдроПовИсп.ПолучитьПодключениеClickHouse();
	Если ВК = Неопределено Тогда
		Возврат "Ошибка: Нет подключения к ClickHouse";
	КонецЕсли;
	
	Попытка
		СыройОтвет = ВК.ВыполнитьКоманду(ТекстЗапросаSQL);
		Возврат КХ_ИнтеграцияСлужебный.ОчиститьСтрокуОтНулей(СыройОтвет);
	Исключение
		Возврат "Ошибка выполнения запроса: " + ОписаниеОшибки();
	КонецПопытки;
	
КонецФункции
//НЕ РАБОТАЕТ, РОНЯЕТ 1С НА ДАННОМ ЭТАПЕ
Процедура СброситьКэшПамяти() Экспорт

	ВК = КХ_ЯдроПовИсп.ПолучитьПодключениеClickHouse();
	Если ВК <> Неопределено Тогда
		Попытка
			ВК.СбросКэша();
		Исключение
			ЗаписьЖурналаРегистрации("ClickHouse.Кэш", УровеньЖурналаРегистрации.Предупреждение,,, 
				"Ошибка при ручном сбросе кэша: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры
// Конвертирует Таблицу Значений в текстовую строку формата TSV с заголовками.
// Автоматически экранирует спецсимволы, обрабатывает пустые даты и значения NULL.
// Сборка происходит полностью в оперативной памяти для максимального быстродействия.
//
// Параметры:
//  ТаблицаДанных - ТаблицаЗначений - Исходная таблица с данными для выгрузки.
//
// Возвращаемое значение:
//  Строка - Текст в формате TSV, готовый для отправки в ClickHouse.
//
Функция КонвертироватьТЗвTSV(ТаблицаДанных) Экспорт
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("tsv");
	ЗаписьТекста = Новый ЗаписьТекста(ИмяВременногоФайла, КодировкаТекста.UTF8);
	
	МассивКолонок = Новый Массив;
	Для Каждого Колонка Из ТаблицаДанных.Колонки Цикл
		МассивКолонок.Добавить(Колонка.Имя);
	КонецЦикла;
	СтрокаЗаголовков = СтрСоединить(МассивКолонок, Символы.Таб);
	ЗаписьТекста.ЗаписатьСтроку(СтрокаЗаголовков);
	
	КоличествоКолонок = МассивКолонок.Количество();
	Для Каждого СтрокаТЗ Из ТаблицаДанных Цикл
		
		МассивЗначений = Новый Массив;
		Для Индекс = 0 По КоличествоКолонок - 1 Цикл
			Значение = СтрокаТЗ[Индекс];

			Если ТипЗнч(Значение) = Тип("Булево") Тогда
				ТекстЗначения = ?(Значение, "true", "false");
			ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда
				ТекстЗначения = Формат(Значение, "ДФ='yyyy-MM-dd HH:mm:ss'");
			ИначеЕсли Значение = Неопределено Или Значение = Null Тогда
				ТекстЗначения = "NULL";
			Иначе
				ТекстЗначения = СтрЗаменить(Строка(Значение), Символы.Таб, " ");
			КонецЕсли;
			
			МассивЗначений.Добавить(ТекстЗначения);
		КонецЦикла;
		
		ЗаписьТекста.ЗаписатьСтроку(СтрСоединить(МассивЗначений, Символы.Таб));
		
	КонецЦикла;
	ЗаписьТекста.Закрыть();
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.Прочитать(ИмяВременногоФайла, КодировкаТекста.UTF8);
	СтрокаTSV = ТекстовыйДокумент.ПолучитьТекст();
	Попытка УдалитьФайлы(ИмяВременногоФайла); Исключение КонецПопытки;
	
	Возврат СтрокаTSV;
КонецФункции
// Выполняет пакетную загрузку всей Таблицы Значений в целевую таблицу ClickHouse.
// Если таблица пустая, процедура завершает работу без вызова компоненты.
//
// Параметры:
//  ИмяТаблицыClickHouse - Строка - Полное имя таблицы (например, "default.logs").
//  ТаблицаДанных        - ТаблицаЗначений - Данные для записи.
//  ВыполнятьПроверку - Булево - Если Истина, проверяет существование таблицы в ClickHouse 
//                               перед отправкой данных. Позволяет быстрее выявить отсутствие 
//                               таблицы, но добавляет накладные расходы на лишний запрос.
//
Процедура ВкачатьТаблицуЗначений(Знач ИмяТаблицыClickHouse, ТаблицаДанных, Знач ВыполнятьПроверку = Ложь) Экспорт
	Если ТаблицаДанных.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаДанныхTSV = КонвертироватьТЗвTSV(ТаблицаДанных);
	
	ВыполнитьПакетнуюВставку(ИмяТаблицыClickHouse, СтрокаДанныхTSV, ВыполнятьПроверку);
КонецПроцедуры