// Инициализирует внешнюю компоненту Rust и создает объект подключения к ClickHouse.
// Поддерживает загрузку как из локального файла на диске, так и из общего макета 1С.
// В случае любой ошибки записывает лог в Журнал Регистрации и возвращает Неопределено.
//
// Возвращаемое значение:
//  ВнешняяКомпонента.CH_Comp.ClickHouse - Инициализированный объект компоненты.
//  Неопределено                         - В случае ошибки подключения или загрузки.
//
Функция ПолучитьПодключениеClickHouse() Экспорт
	Настройки = КХ_ИнтеграцияСлужебный.ПолучитьНастройкиИзРегистра();
	
	Попытка
		ИмяСборки = "CH_Comp";
		Если ПустаяСтрока(Настройки.ПутьККомпоненте) Тогда
			ИсточникЗагрузки = "ОбщийМакет.КХ_ВК";
			ИмяТипаОбъекта   = "AddIn." + ИмяСборки + ".ClickHouse"; // Для макета пробуем стандартный синтаксис
		Иначе
			ИсточникЗагрузки = Настройки.ПутьККомпоненте;
			ИмяТипаОбъекта   = "AddIn." + ИмяСборки + ".ClickHouse"; // Для dll на диске
		КонецЕсли;
		
		Подключено = ПодключитьВнешнююКомпоненту(ИсточникЗагрузки, ИмяСборки, ТипВнешнейКомпоненты.Native);
		Если НЕ Подключено Тогда
			ВызватьИсключение "Платформа 1С вернула Ложь при загрузке бинарника.";
		КонецЕсли;
		
		ВК_Объект = Новый(ИмяТипаОбъекта);
		
		Если Не ВК_Объект.Подключиться(Настройки.АдресСервера, Настройки.Пользователь, Настройки.Пароль) Тогда
			ВызватьИсключение "Компонента Rust отказала в авторизации сессии ClickHouse.";
		КонецЕсли;
		
		Возврат ВК_Объект;
	Исключение
		ЗаписьЖурналаРегистрации("ClickHouse.Ядро", УровеньЖурналаРегистрации.Ошибка,,, 
			"Критическая ошибка инициализации ядра ClickHouse: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
КонецФункции