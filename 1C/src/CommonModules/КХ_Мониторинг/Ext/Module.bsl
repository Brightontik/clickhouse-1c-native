// Инициализирует структуру для замера длительности операции.
// Используется в паре с процедурой ФиксироватьМетрику.
//
// Параметры:
//  ТипСобытия - Строка - Категория замера (например, "HTTP", "Query", "Report").
//  ИмяСобытия - Строка - Уникальный идентификатор операции (например, "ВыгрузкаОстатков").
//
// Возвращаемое значение:
//  Структура - Контейнер с данными замера:
//   * ТипСобытия  - Строка - Переданный тип события.
//   * ИмяСобытия  - Строка - Переданное имя события.
//   * ВремяСтарта - Число  - Время начала замера в миллисекундах.
//   * Контекст    - Структура - Произвольные дополнительные данные для логирования.
//
Функция НачатьЗамер(Знач ТипСобытия, Знач ИмяСобытия) Экспорт
	Метрика = Новый Структура();
	Метрика.Вставить("ТипСобытия",  ТипСобытия);
	Метрика.Вставить("ИмяСобытия",  ИмяСобытия);
	Метрика.Вставить("ВремяСтарта", ТекущаяУниверсальнаяДатаВМиллисекундах());
	Метрика.Вставить("Контекст",    Новый Структура);
	
	Возврат Метрика;
КонецФункции

// Вычисляет длительность операции и отправляет собранную метрику в ClickHouse.
// Безопасна к сбоям: ошибки отправки не прерывают основной код пользователя.
//
// Параметры:
//  Метрика - Структура - Объект замера, полученный ранее из функции НачатьЗамер.
//  Статус  - Строка    - Результат выполнения операции ("Success", "Error" и т.д.).
//
Процедура ФиксироватьМетрику(Метрика, Знач Статус = "Success") Экспорт
	ДлительностьМС = ТекущаяУниверсальнаяДатаВМиллисекундах() - Метрика.ВремяСтарта;
	ТекущийПользователь = ИмяПользователя();
	Если ПустаяСтрока(ТекущийПользователь) Тогда
		ТекущийПользователь = "System";
	КонецЕсли;
		
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Метрика.Контекст);
	СтрокаКонтекстаJSON = ЗаписьJSON.Закрыть();
	
	ВК = КХ_ЯдроПовИсп.ПолучитьПодключениеClickHouse();
	
	Если ВК <> Неопределено Тогда
		Попытка
			ВК.ЛогМетрики(
				Метрика.ТипСобытия,
				Метрика.ИмяСобытия,
				ДлительностьМС,
				Статус,
				ТекущийПользователь,
				СтрокаКонтекстаJSON
			);
		Исключение
			ЗаписьЖурналаРегистрации("ClickHouse.Метрики", УровеньЖурналаРегистрации.Предупреждение,,, 
				"Сбой отправки метрики: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры